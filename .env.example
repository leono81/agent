# =========================
# JIRA CONFIGURATION
# =========================
# URL de tu instancia Jira (Cloud o Server/Data Center)
# Ej Cloud: https://tu-dominio.atlassian.net
# Ej Server: https://jira.tu-empresa.com
JIRA_URL=

# --- Autenticación Cloud ---
# Tu email de Atlassian
JIRA_USERNAME=
# Tu API Token generado desde id.atlassian.com
JIRA_API_TOKEN=

# --- Autenticación Server/Data Center (alternativa a la de Cloud) ---
# Tu Personal Access Token (PAT) generado en tu perfil de Jira Server/DC
# JIRA_PERSONAL_TOKEN=

# (Opcional - Server/DC) Deshabilitar verificación SSL si usas certificados autofirmados
# JIRA_SSL_VERIFY=false

# =========================
# LLM CONFIGURATION (Ejemplo para OpenAI, adaptar según tu proveedor)
# =========================
# URL base del API del LLM
# OpenAI: https://api.openai.com/v1
# OpenRouter: https://openrouter.ai/api/v1
# Ollama local: http://localhost:11434/v1
BASE_URL=https://api.openai.com/v1

# Clave API para el proveedor LLM (OpenAI, OpenRouter, etc.)
# Para Ollama local, puedes poner 'ollama' o dejarlo vacío si no requiere clave.
LLM_API_KEY=

# Modelo LLM principal a usar para el agente conversacional
# Ejemplos: gpt-4o-mini, claude-3-haiku-20240307, ollama/llama3
PRIMARY_MODEL=gpt-4o-mini

# =========================
# LOGGING CONFIGURATION (Opcional)
# =========================
# Niveles: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO